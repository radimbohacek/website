    <item>
      <title>Daniel Barenboim, CSO: Giya Kancheli Lament, Music of Mourning in Memory of Luigi Nono</title>
      <link>https://walse.cz/koncert/19981022-cso-barenboim-kancheli/</link>
      <pubDate>Thu, 22 Oct 1998 00:00:00 +0000</pubDate>
      <guid>https://walse.cz/koncert/19981022-cso-barenboim-kancheli/</guid>
      <description>&lt;table&gt;
  &lt;thead&gt;
      &lt;tr&gt;
          &lt;th style=&#34;text-align: left&#34;&gt;&lt;/th&gt;
          &lt;th style=&#34;text-align: left&#34;&gt;&lt;/th&gt;
      &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;Chicago Symphony Orchestra&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;Daniel Barenboim&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;Gidon Kremer&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;violin&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;Katharina Kammerloher&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;mezzo-soprano&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;Giya Kancheli&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;Lament, Music of Mourning in Memory of Luigi Nono&lt;/td&gt;
      &lt;/tr&gt;
